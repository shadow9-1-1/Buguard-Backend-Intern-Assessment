{
  "info": {
    "name": "Buguard Assets API - Automated Tests",
    "description": "Full test suite for the Assets API including CRUD, filtering, sorting, and pagination.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "0. Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var d = pm.response.json();",
              "pm.environment.set('access_token', d.access_token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "username",
              "value": "admin",
              "type": "text"
            },
            {
              "key": "password",
              "value": "admin",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/v1/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "login"]
        }
      }
    },
    {
      "name": "1. Create Asset",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Response has an ID\", function () {",
              "    pm.expect(jsonData.id).to.exist;",
              "});",
              "",
              "pm.test(\"Asset type matches\", function () {",
              "    pm.expect(jsonData.type).to.eql(\"domain\");",
              "});",
              "",
              "pm.test(\"first_seen is set\", function () {",
              "    pm.expect(jsonData.first_seen).to.exist;",
              "});",
              "",
              "pm.test(\"last_seen is set\", function () {",
              "    pm.expect(jsonData.last_seen).to.exist;",
              "});",
              "",
              "// Save the ID to the environment variable for subsequent requests",
              "if (jsonData.id) {",
              "    pm.environment.set(\"asset_id\", jsonData.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"domain\",\n  \"value\": \"example-api-{{$timestamp}}.com\",\n  \"status\": \"active\",\n  \"tags\": [\"automation\", \"test\"]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/assets/",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", ""]
        }
      }
    },
    {
      "name": "2. Get Asset by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Asset ID matches environment variable\", function () {",
              "    pm.expect(jsonData.id).to.eql(pm.environment.get(\"asset_id\"));",
              "});",
              "",
              "pm.test(\"Asset has expected fields\", function () {",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData).to.have.property('type');",
              "    pm.expect(jsonData).to.have.property('value');",
              "    pm.expect(jsonData).to.have.property('status');",
              "    pm.expect(jsonData).to.have.property('first_seen');",
              "    pm.expect(jsonData).to.have.property('last_seen');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/assets/{{asset_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "{{asset_id}}"]
        }
      }
    },
    {
      "name": "3a. List Assets - Default Pagination",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Response has pagination fields\", function () {",
              "    pm.expect(jsonData).to.have.property('items');",
              "    pm.expect(jsonData).to.have.property('total');",
              "    pm.expect(jsonData).to.have.property('page');",
              "    pm.expect(jsonData).to.have.property('size');",
              "});",
              "",
              "pm.test(\"Default page is 1\", function () {",
              "    pm.expect(jsonData.page).to.eql(1);",
              "});",
              "",
              "pm.test(\"Default page size is 50\", function () {",
              "    pm.expect(jsonData.size).to.eql(50);",
              "});",
              "",
              "pm.test(\"Items is an array\", function () {",
              "    pm.expect(jsonData.items).to.be.an('array');",
              "});",
              "",
              "pm.test(\"Total is a number\", function () {",
              "    pm.expect(jsonData.total).to.be.a('number');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/assets/",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", ""]
        }
      }
    },
    {
      "name": "3b. List Assets - Custom Page Size",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Page size matches requested size\", function () {",
              "    pm.expect(jsonData.size).to.eql(5);",
              "});",
              "",
              "pm.test(\"Page matches requested page\", function () {",
              "    pm.expect(jsonData.page).to.eql(1);",
              "});",
              "",
              "pm.test(\"Items returned do not exceed page size\", function () {",
              "    pm.expect(jsonData.items.length).to.be.at.most(5);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/assets/?page=1&size=5",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", ""],
          "query": [
            {"key": "page", "value": "1"},
            {"key": "size", "value": "5"}
          ]
        }
      }
    },
    {
      "name": "3c. List Assets - Sort by value ASC",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Response has items\", function () {",
              "    pm.expect(jsonData.items).to.be.an('array');",
              "});",
              "",
              "pm.test(\"Items are sorted ascending by value\", function () {",
              "    var items = jsonData.items;",
              "    if (items.length > 1) {",
              "        for (var i = 0; i < items.length - 1; i++) {",
              "            pm.expect(items[i].value.toLowerCase() <= items[i+1].value.toLowerCase()).to.be.true;",
              "        }",
              "    } else {",
              "        pm.expect(true).to.be.true; // pass if only 1 or 0 items",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/assets/?sort_by=value&sort_order=asc",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", ""],
          "query": [
            {"key": "sort_by", "value": "value"},
            {"key": "sort_order", "value": "asc"}
          ]
        }
      }
    },
    {
      "name": "3d. List Assets - Sort by first_seen DESC (default)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Response has items\", function () {",
              "    pm.expect(jsonData.items).to.be.an('array');",
              "});",
              "",
              "pm.test(\"Items are sorted descending by first_seen\", function () {",
              "    var items = jsonData.items;",
              "    if (items.length > 1) {",
              "        for (var i = 0; i < items.length - 1; i++) {",
              "            var d1 = new Date(items[i].first_seen);",
              "            var d2 = new Date(items[i+1].first_seen);",
              "            pm.expect(d1 >= d2).to.be.true;",
              "        }",
              "    } else {",
              "        pm.expect(true).to.be.true;",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/assets/?sort_by=first_seen&sort_order=desc",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", ""],
          "query": [
            {"key": "sort_by", "value": "first_seen"},
            {"key": "sort_order", "value": "desc"}
          ]
        }
      }
    },
    {
      "name": "3e. List Assets - Filter by type and tag",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"All items are of type domain\", function () {",
              "    jsonData.items.forEach(function(item) {",
              "        pm.expect(item.type.toLowerCase()).to.eql(\"domain\");",
              "    });",
              "});",
              "",
              "pm.test(\"Items array has at least 1 element\", function () {",
              "    pm.expect(jsonData.items.length).to.be.above(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/assets/?page=1&size=10&asset_type=domain&tag=automation",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", ""],
          "query": [
            {"key": "page", "value": "1"},
            {"key": "size", "value": "10"},
            {"key": "asset_type", "value": "domain"},
            {"key": "tag", "value": "automation"}
          ]
        }
      }
    },
    {
      "name": "4. Update Asset (PUT)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Value is updated\", function () {",
              "    pm.expect(jsonData.value).to.include(\"updated-\");",
              "});",
              "",
              "pm.test(\"first_seen is unchanged (immutable)\", function () {",
              "    pm.expect(jsonData.first_seen).to.exist;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"domain\",\n  \"value\": \"updated-example-{{$timestamp}}.com\",\n  \"status\": \"active\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/assets/{{asset_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "{{asset_id}}"]
        }
      }
    },
    {
      "name": "5. Partially Update Asset (PATCH)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Status is stale\", function () {",
              "    pm.expect(jsonData.status).to.eql(\"stale\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"stale\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/assets/{{asset_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "{{asset_id}}"]
        }
      }
    },
    {
      "name": "6. Delete Asset (soft delete)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Status is archived (soft delete)\", function () {",
              "    pm.expect(jsonData.status).to.eql(\"archived\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{base_url}}/api/v1/assets/{{asset_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "{{asset_id}}"]
        }
      }
    },
    {
      "name": "7. Get Non-Existent Asset (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test(\"Error detail is returned\", function () {",
              "    pm.expect(pm.response.json()).to.have.property('detail');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/assets/00000000-0000-0000-0000-000000000000",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "00000000-0000-0000-0000-000000000000"]
        }
      }
    },
    {
      "name": "8a. Bulk Import - Happy Path",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Summary has required fields\", function () {",
              "    pm.expect(jsonData).to.have.property('total');",
              "    pm.expect(jsonData).to.have.property('imported');",
              "    pm.expect(jsonData).to.have.property('skipped');",
              "    pm.expect(jsonData).to.have.property('duplicates');",
              "    pm.expect(jsonData).to.have.property('errors');",
              "});",
              "",
              "pm.test(\"Total equals number of records sent\", function () {",
              "    pm.expect(jsonData.total).to.eql(3);",
              "});",
              "",
              "pm.test(\"All valid records are imported\", function () {",
              "    pm.expect(jsonData.imported).to.eql(3);",
              "});",
              "",
              "pm.test(\"No records skipped\", function () {",
              "    pm.expect(jsonData.skipped).to.eql(0);",
              "});",
              "",
              "pm.test(\"Errors list is empty\", function () {",
              "    pm.expect(jsonData.errors).to.be.an('array').that.is.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assets\": [\n    {\"type\": \"domain\", \"value\": \"bulk-import-1-{{$timestamp}}.com\", \"status\": \"active\", \"tags\": [\"bulk\"]},\n    {\"type\": \"ip\", \"value\": \"192.168.{{$randomInt}}.1\", \"status\": \"active\", \"tags\": [\"bulk\"]},\n    {\"type\": \"url\", \"value\": \"https://bulk-import-3-{{$timestamp}}.com/path\", \"status\": \"active\", \"tags\": [\"bulk\"]}\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/assets/import",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "import"]
        }
      }
    },
    {
      "name": "8b. Bulk Import - Mixed Valid and Invalid",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Total equals 3 records sent\", function () {",
              "    pm.expect(jsonData.total).to.eql(3);",
              "});",
              "",
              "pm.test(\"Valid records are imported\", function () {",
              "    pm.expect(jsonData.imported).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Invalid records are skipped\", function () {",
              "    pm.expect(jsonData.skipped).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Errors contain details for skipped records\", function () {",
              "    pm.expect(jsonData.errors.length).to.be.above(0);",
              "    pm.expect(jsonData.errors[0]).to.have.property('index');",
              "    pm.expect(jsonData.errors[0]).to.have.property('reason');",
              "    pm.expect(jsonData.errors[0]).to.have.property('record');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assets\": [\n    {\"type\": \"domain\", \"value\": \"mixed-valid-{{$timestamp}}.com\", \"status\": \"active\"},\n    {\"type\": \"INVALID_TYPE\", \"value\": \"this-should-fail.com\"},\n    {\"value\": \"missing-type-field.com\"}\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/assets/import",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "import"]
        }
      }
    },
    {
      "name": "8c. Bulk Import - All Duplicates",
      "event": [
        {
          "listen": "preRequest",
          "script": {
            "exec": [
              "// This seeds a fixed asset so the next request can merge into it",
              "pm.environment.set('dedup_value', 'dedup-test-fixed-' + Date.now() + '.com');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Asset seeded (imported = 1)\", function () {",
              "    pm.expect(jsonData.imported).to.eql(1);",
              "});",
              "",
              "pm.test(\"Nothing merged yet\", function () {",
              "    pm.expect(jsonData.merged).to.eql(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assets\": [\n    {\"type\": \"domain\", \"value\": \"{{dedup_value}}\", \"status\": \"active\", \"tags\": [\"original\"], \"metadata\": {\"source\": \"seed\", \"priority\": 1}}\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/assets/import",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "import"]
        }
      }
    },
    {
      "name": "9b. Deduplication - Re-import same asset (merge tags & metadata)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Nothing new imported (was duplicate)\", function () {",
              "    pm.expect(jsonData.imported).to.eql(0);",
              "});",
              "",
              "pm.test(\"Duplicate was merged (merged = 1)\", function () {",
              "    pm.expect(jsonData.merged).to.eql(1);",
              "});",
              "",
              "pm.test(\"No records skipped\", function () {",
              "    pm.expect(jsonData.skipped).to.eql(0);",
              "});",
              "",
              "pm.test(\"Total = imported + merged + skipped\", function () {",
              "    pm.expect(jsonData.total).to.eql(jsonData.imported + jsonData.merged + jsonData.skipped);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assets\": [\n    {\"type\": \"domain\", \"value\": \"{{dedup_value}}\", \"status\": \"stale\", \"tags\": [\"merged-tag\", \"extra\"], \"metadata\": {\"source\": \"reimport\", \"confidence\": 99}}\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/assets/import",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "import"]
        }
      }
    },
    {
      "name": "9c. Deduplication - Verify tags & metadata merged on asset",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": ["// asset_id should already be set from test 1 if using the same env"],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Tags from both imports are present (union)\", function () {",
              "    var tags = jsonData.items.length > 0 ? jsonData.items[0].tags : [];",
              "    pm.expect(tags).to.include('original');",
              "    pm.expect(tags).to.include('merged-tag');",
              "    pm.expect(tags).to.include('extra');",
              "});",
              "",
              "pm.test(\"Metadata was merged (new key added, existing key overwritten)\", function () {",
              "    var meta = jsonData.items.length > 0 ? jsonData.items[0].metadata : {};",
              "    pm.expect(meta).to.have.property('source');",
              "    pm.expect(meta.source).to.eql('reimport');",
              "    pm.expect(meta).to.have.property('priority');",
              "    pm.expect(meta).to.have.property('confidence');",
              "    pm.expect(meta.confidence).to.eql(99);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/assets/?search={{dedup_value}}&size=1",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", ""],
          "query": [
            {"key": "search", "value": "{{dedup_value}}"},
            {"key": "size", "value": "1"}
          ]
        }
      }
    }
  ],
  "item_lifecycle": "--- lifecycle tests appended below ---",
  "item": [
    {
      "name": "10a. Lifecycle - Create asset and capture first_seen",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "var d = pm.response.json();",
              "pm.test(\"first_seen is set on creation\", function () {",
              "    pm.expect(d.first_seen).to.exist;",
              "});",
              "pm.test(\"last_seen is set on creation\", function () {",
              "    pm.expect(d.last_seen).to.exist;",
              "});",
              "pm.test(\"Status is active\", function () {",
              "    pm.expect(d.status).to.eql('active');",
              "});",
              "pm.environment.set('lifecycle_asset_id', d.id);",
              "pm.environment.set('lifecycle_first_seen', d.first_seen);",
              "pm.environment.set('lifecycle_last_seen', d.last_seen);",
              "pm.environment.set('lifecycle_value', d.value);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"domain\",\n  \"value\": \"lifecycle-{{$timestamp}}.com\",\n  \"status\": \"active\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/assets/",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", ""]
        }
      }
    },
    {
      "name": "10b. Lifecycle - Record sighting updates last_seen",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var d = pm.response.json();",
              "pm.test(\"first_seen is UNCHANGED (immutable)\", function () {",
              "    pm.expect(d.first_seen).to.eql(pm.environment.get('lifecycle_first_seen'));",
              "});",
              "pm.test(\"last_seen is updated after sighting\", function () {",
              "    var before = new Date(pm.environment.get('lifecycle_last_seen'));",
              "    var after  = new Date(d.last_seen);",
              "    pm.expect(after >= before).to.be.true;",
              "});",
              "pm.environment.set('lifecycle_last_seen', d.last_seen);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/api/v1/assets/{{lifecycle_asset_id}}/sight",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "{{lifecycle_asset_id}}", "sight"]
        }
      }
    },
    {
      "name": "10c. Lifecycle - Stale asset reactivated by sighting",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// First mark the asset as stale via PATCH (done inline by the test runner before this request)"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var d = pm.response.json();",
              "pm.test(\"Status is reactivated to active\", function () {",
              "    pm.expect(d.status).to.eql('active');",
              "});",
              "pm.test(\"first_seen is still unchanged\", function () {",
              "    pm.expect(d.first_seen).to.eql(pm.environment.get('lifecycle_first_seen'));",
              "});",
              "pm.test(\"last_seen updated on reactivation\", function () {",
              "    pm.expect(d.last_seen).to.exist;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/api/v1/assets/{{lifecycle_asset_id}}/sight",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "{{lifecycle_asset_id}}", "sight"]
        }
      }
    },
    {
      "name": "10c-pre. Lifecycle - Mark asset stale (before reactivation test)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Asset is now stale\", function () {",
              "    pm.expect(pm.response.json().status).to.eql('stale');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "url": {
          "raw": "{{base_url}}/api/v1/assets/{{lifecycle_asset_id}}/stale",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "{{lifecycle_asset_id}}", "stale"]
        }
      }
    },
    {
      "name": "10d. Lifecycle - Archived asset blocks sighting (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 400 for archived asset\", function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test(\"Error detail mentions archived\", function () {",
              "    pm.expect(pm.response.json().detail.toLowerCase()).to.include('archived');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/api/v1/assets/{{asset_id}}/sight",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "{{asset_id}}", "sight"]
        }
      }
    },
    {
      "name": "10e. Lifecycle - Stale asset reactivated via bulk import merge",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var d = pm.response.json();",
              "pm.test(\"Stale asset was merged (not skipped)\", function () {",
              "    pm.expect(d.merged).to.be.above(0);",
              "});",
              "pm.test(\"Nothing counted as error\", function () {",
              "    pm.expect(d.skipped).to.eql(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"assets\": [\n    {\"type\": \"domain\", \"value\": \"{{lifecycle_value}}\", \"status\": \"active\", \"tags\": [\"reimported\"]}\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/assets/import",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "assets", "import"]
        }
      }
    }
  ],
